import 'http://mdelab.de/intempo/examples/shs/1.0'

($u1 , ! (true U[0,3600] E ($u11, true)))

declarations{
	
	u1{
		root:SHSService
		pm:PMonitoringService
		root -connected-> pm
		pr1:Probe
		pm -probes-> pr1
		[OCL:"pr1.status='sepsis'"]
	}	
	
	u11{
		root:SHSService
		pm:PMonitoringService
		root -connected-> pm
		d:DrugService
		root -connected-> d
		pr2:Probe
		d -probes-> pr2
		[OCL:"pr2.status='anti' and pm.pID = d.pID"]
	}	
}